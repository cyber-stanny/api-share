# CloudBase 环境 ID
CLOUDBASE_ENV_ID=your-cloudbase-env-id

# JWT 签名密钥（请使用随机字符串）
JWT_SECRET=your-random-secret-key

# 管理员初始密码
ADMIN_INIT_PASSWORD=your-admin-password

# CORS 白名单，多个域名用英文逗号分隔
CORS_ORIGINS=https://your-domain.example.com

# 上游 API Keys
SILICONFLOW_API_KEY=your-siliconflow-api-key
MIMO_API_KEY=your-mimo-api-key

# MiMo Token Plan 上游保护：8 并发、10 队列、最多等待 30 秒、每分钟 80 次
UPSTREAM_MIMO_MAX_CONCURRENT=8
UPSTREAM_MIMO_MAX_QUEUE=10
UPSTREAM_MIMO_QUEUE_TIMEOUT_MS=30000
UPSTREAM_MIMO_RPM=80
