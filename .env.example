# CloudBase 环境 ID
CLOUDBASE_ENV_ID=your-cloudbase-env-id

# 独立服务器访问 CloudBase 数据库需要腾讯云 API 密钥。
# 在 CloudBase 云函数内运行时可不填；在 ECS/轻量服务器上部署时必须配置。
TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key

# JWT 签名密钥（请使用随机字符串）
JWT_SECRET=your-random-secret-key

# 管理员初始密码
ADMIN_INIT_PASSWORD=your-admin-password

# CORS 白名单，多个域名用英文逗号分隔
CORS_ORIGINS=https://your-domain.example.com

# 是否启用 /v1 API 代理。CloudBase 免费版可设为 false，仅保留注册、登录、管理和 Key 发放。
# 独立服务器完整部署时保持 true。
PROXY_ENABLED=true

# 上游 API Keys
SILICONFLOW_API_KEY=your-siliconflow-api-key
MIMO_API_KEY=your-mimo-api-key
MINIMAX_API_KEY=your-minimax-api-key

# MiMo Token Plan 上游保护：8 并发、10 队列、最多等待 30 秒、每分钟 80 次
UPSTREAM_MIMO_MAX_CONCURRENT=8
UPSTREAM_MIMO_MAX_QUEUE=10
UPSTREAM_MIMO_QUEUE_TIMEOUT_MS=30000
UPSTREAM_MIMO_RPM=80

# MiniMax Token Plan 上游保护：默认沿用 MiMo 的限流参数
UPSTREAM_MINIMAX_MAX_CONCURRENT=8
UPSTREAM_MINIMAX_MAX_QUEUE=10
UPSTREAM_MINIMAX_QUEUE_TIMEOUT_MS=30000
UPSTREAM_MINIMAX_RPM=80

# MiniMax 学生调用限制：按请求次数计算，highspeed 不额外加倍
MINIMAX_DAILY_REQUEST_LIMIT=1000
MINIMAX_WEEKLY_REQUEST_LIMIT=4000
