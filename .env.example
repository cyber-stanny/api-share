# CloudBase 环境 ID
CLOUDBASE_ENV_ID=your-cloudbase-env-id

# 独立服务器访问 CloudBase 数据库需要腾讯云 API 密钥。
# 在 CloudBase 云函数内运行时可不填；在 ECS/轻量服务器上部署时必须配置。
TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key
TENCENTCLOUD_REGION=ap-shanghai

# JWT 签名密钥（请使用随机字符串）
JWT_SECRET=your-random-secret-key

# 管理员初始密码
ADMIN_INIT_PASSWORD=your-admin-password

# CORS 白名单，多个域名用英文逗号分隔
CORS_ORIGINS=https://your-domain.example.com

# 是否启用 /v1 API 代理。CloudBase 免费版可设为 false，仅保留注册、登录、管理和 Key 发放。
# 独立服务器完整部署时保持 true。
PROXY_ENABLED=true

# 上游 API Keys
# MiMo / Aliyun 已停用，保留变量仅用于历史部署兼容。
MIMO_API_KEY=
ALIYUN_API_KEY=
DEEPSEEK_API_KEY=your-deepseek-official-api-key
GLM_API_KEY=your-zhipu-glm-official-api-key

# 本地验证新供应商时可设为 true：使用当前代码预设和本地 Key，不读取 upstreams 配置表
LOCAL_UPSTREAM_PRESETS=false

# MiMo Token Plan 上游保护：已停用，保留变量仅用于历史部署兼容。
UPSTREAM_MIMO_MAX_CONCURRENT=8
UPSTREAM_MIMO_MAX_QUEUE=10
UPSTREAM_MIMO_QUEUE_TIMEOUT_MS=30000
UPSTREAM_MIMO_RPM=80

# Aliyun Token Plan 上游保护：已停用，保留变量仅用于历史部署兼容。
UPSTREAM_ALIYUN_MAX_CONCURRENT=8
UPSTREAM_ALIYUN_MAX_QUEUE=10
UPSTREAM_ALIYUN_QUEUE_TIMEOUT_MS=30000
UPSTREAM_ALIYUN_RPM=80

# DeepSeek 官方 API 上游保护
UPSTREAM_DEEPSEEK_MAX_CONCURRENT=100
UPSTREAM_DEEPSEEK_MAX_QUEUE=100
UPSTREAM_DEEPSEEK_QUEUE_TIMEOUT_MS=30000
UPSTREAM_DEEPSEEK_RPM=1000

# 智谱 GLM 官方 API 上游保护（实际账户并发以智谱控制台为准）
UPSTREAM_GLM_MAX_CONCURRENT=20
UPSTREAM_GLM_MAX_QUEUE=50
UPSTREAM_GLM_QUEUE_TIMEOUT_MS=30000
UPSTREAM_GLM_RPM=300

# DeepSeek 学生金额额度（人民币）
DEEPSEEK_DAILY_COST_LIMIT_CNY=5
DEEPSEEK_WEEKLY_COST_LIMIT_CNY=20
GLM_DAILY_COST_LIMIT_CNY=5
GLM_WEEKLY_COST_LIMIT_CNY=20
